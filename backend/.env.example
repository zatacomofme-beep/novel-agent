# App
APP_NAME=Long Novel Agent
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/novel_agent

# Cache / Queue
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Vector Store
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=story_bible
QDRANT_REQUEST_TIMEOUT_SECONDS=5
VECTOR_EMBEDDING_DIMENSIONS=128

# Auth
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=claude-3-5-sonnet
MODEL_REQUEST_TIMEOUT_SECONDS=45
MODEL_MAX_RETRIES=2
REDIS_TASK_EVENTS_CHANNEL_PREFIX=task_updates

# Logging
LOG_LEVEL=INFO
