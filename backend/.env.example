# 本文件面向“本机直跑后端 / worker”。
# 如果你使用根目录 docker-compose，请改看 backend/.env.compose.example。

# App
APP_NAME="Long Novel Agent"
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
# compat: 兼容旧 /api/v1/chapters/*；gone: 直接返回 410（演练/下线阶段）
LEGACY_CHAPTER_ROUTES_MODE=compat

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/novel_agent

# Cache / Queue
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=story_bible
QDRANT_REQUEST_TIMEOUT_SECONDS=5
VECTOR_EMBEDDING_DIMENSIONS=128
STORY_ENGINE_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# Auth
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_GATEWAY_API_KEY=
MODEL_GATEWAY_BASE_URL=https://yunwu.ai/v1
DEFAULT_MODEL=gpt-5.4
STORY_ENGINE_OUTLINE_MODEL=gpt-5.4
STORY_ENGINE_GUARDIAN_MODEL=gpt-5.4
STORY_ENGINE_LOGIC_MODEL=claude-opus-4-6
STORY_ENGINE_COMMERCIAL_MODEL=deepseek-v3.2
STORY_ENGINE_STYLE_MODEL=gemini-3.1-pro-preview
STORY_ENGINE_ANCHOR_MODEL=gpt-5.4
STORY_ENGINE_ARBITRATOR_MODEL=gpt-5.4
STORY_ENGINE_STREAM_MODEL=gpt-5.4
STORY_ENGINE_OUTLINE_MAX_DEBATE_ROUNDS=5
STORY_ENGINE_FINAL_VERIFY_MAX_ROUNDS=6
MODEL_REQUEST_TIMEOUT_SECONDS=45
MODEL_MAX_RETRIES=2
REDIS_TASK_EVENTS_CHANNEL_PREFIX=task_updates

# Logging
LOG_LEVEL=INFO
